# Local FastAPI database connection
DATABASE_URL=postgresql+asyncpg://todo:todo@127.0.0.1:5432/todo

# Docker Compose PostgreSQL settings
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=todo
POSTGRES_PORT=5433

# Docker Compose API port
API_PORT=8000

# Local observability ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana development login (change outside local development)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
